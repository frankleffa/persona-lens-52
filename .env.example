# Supabase — copie este arquivo para .env e preencha com suas credenciais reais
# Encontre esses valores em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api

VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
VITE_SUPABASE_URL="https://seu-project-id-aqui.supabase.co"

# Stripe — obtenha em https://dashboard.stripe.com/apikeys
# Price ID do Plano Fundadores (criar em Stripe Dashboard > Produtos)
VITE_STRIPE_FOUNDERS_PRICE_ID="price_xxxxxxxxxxxxxxxxxx"
