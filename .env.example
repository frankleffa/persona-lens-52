# Supabase (cliente) — chaves públicas, embarcadas no bundle
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Evolution API (WhatsApp)
# ATENÇÃO: use HTTPS em produção. Um endpoint http:// é bloqueado pelo navegador
# (mixed content) quando o app roda sob HTTPS no Vercel.
VITE_EVOLUTION_API_URL="https://seu-host-evolution"
VITE_EVOLUTION_API_KEY="sua-evolution-key"
